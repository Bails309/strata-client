# ─── Strata Client – Caddy Reverse Proxy ───────────────────────────
# All traffic flows through Caddy.
# Plain HTTP by default; set STRATA_DOMAIN to a real domain for
# automatic Let's Encrypt HTTPS.
#
# Usage:
#   docker compose up -d                              # HTTP on :80
#   STRATA_DOMAIN=strata.example.com docker compose up -d  # auto-HTTPS
#
# SECURITY NOTE — Transport
#   Vault and guacd communicate over plaintext within the Docker bridge
#   network. For high-security deployments, enable Vault TLS or use
#   Docker encrypted overlay networks.
#
# SECURITY NOTE — Logging
#   If you enable access logging, strip token query parameters to
#   prevent JWT leakage:
#     log { output file /var/log/caddy/access.log; format filter { wrap json; fields { request>uri query { delete token } } } }
# ───────────────────────────────────────────────────────────────────

{$STRATA_DOMAIN::80} {
	# API and WebSocket traffic → Rust backend
	handle /api/* {
		reverse_proxy backend:8080 {
			# Long-lived WebSocket tunnels for remote sessions
			transport http {
				read_timeout  3600s
				write_timeout 3600s
			}
			# Stream frames immediately — no response buffering
			flush_interval -1
		}
	}

	# Everything else → nginx frontend container (SPA static files)
	handle {
		reverse_proxy frontend:80
	}

	# Compression
	encode gzip zstd

	# Security headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}

	# HSTS only when serving over TLS (real domain with certificate)
	@https protocol https
	header @https Strict-Transport-Security "max-age=31536000; includeSubDomains"
}
