From: Strata Client maintainers
Subject: [PATCH] rdp: use AuthenticateEx callback on FreeRDP >= 3.25

FreeRDP 3.25 removed the legacy `Authenticate` callback field from
`struct rdp_freerdp`; only `AuthenticateEx` remains, which carries an
extra `rdp_auth_reason reason` parameter. This breaks the build of
guacamole-server 1.6.1 (commit 2980cf0) on Alpine edge, whose
`freerdp-dev` package was bumped from 3.24.2-r0 to 3.25.0-r0:

  src/protocols/rdp/rdp.c:554:15: error:
    'freerdp' {aka 'struct rdp_freerdp'} has no member named
    'Authenticate'; did you mean 'AuthenticateEx'?

This patch uses the FreeRDP version macros defined in
<freerdp/version.h> (transitively included via <freerdp/freerdp.h>) to
select the correct callback and signature at compile time, keeping
compatibility with FreeRDP 3.24 while restoring the build on 3.25+.

The added `rdp_auth_reason` parameter is intentionally ignored: the
existing implementation already requests whichever credentials are
missing, regardless of the reason FreeRDP raised the callback.
---
 src/protocols/rdp/rdp.c | 16 ++++++++++++++++
 1 file changed, 16 insertions(+)

diff --git a/src/protocols/rdp/rdp.c b/src/protocols/rdp/rdp.c
--- a/src/protocols/rdp/rdp.c
+++ b/src/protocols/rdp/rdp.c
@@ -360,8 +360,15 @@
  * @return
  *     Always TRUE.
  */
+#if defined(FREERDP_VERSION_MAJOR) && \
+    (FREERDP_VERSION_MAJOR > 3 || \
+     (FREERDP_VERSION_MAJOR == 3 && FREERDP_VERSION_MINOR >= 25))
+static BOOL rdp_freerdp_authenticate(freerdp* instance, char** username,
+        char** password, char** domain, rdp_auth_reason reason) {
+#else
 static BOOL rdp_freerdp_authenticate(freerdp* instance, char** username,
         char** password, char** domain) {
+#endif
 
     rdpContext* context = GUAC_RDP_CONTEXT(instance);
     guac_client* client = ((rdp_freerdp_context*) context)->client;
@@ -551,7 +558,16 @@
         rdp_inst->LoadChannels = rdp_freerdp_load_channels;
     #endif
     rdp_inst->PreConnect = rdp_freerdp_pre_connect;
+#if defined(FREERDP_VERSION_MAJOR) && \
+    (FREERDP_VERSION_MAJOR > 3 || \
+     (FREERDP_VERSION_MAJOR == 3 && FREERDP_VERSION_MINOR >= 25))
+    /* FreeRDP 3.25 removed the legacy Authenticate callback in favour of
+     * AuthenticateEx, which adds an rdp_auth_reason parameter. */
+    rdp_inst->AuthenticateEx = rdp_freerdp_authenticate;
+#else
     rdp_inst->Authenticate = rdp_freerdp_authenticate;
+#endif
 
 #ifdef HAVE_FREERDP_VERIFYCERTIFICATEEX
     rdp_inst->VerifyCertificateEx = rdp_freerdp_verify_certificate;
