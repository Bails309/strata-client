# ── Strata Client Environment ─────────────────────────────────────────
#
# Copy to `.env` and fill in real values BEFORE running production
# `docker compose up`. The backend will emit `error!`-level startup
# warnings when any of these are unset, weak, or left at a dev default
# (see `log_security_config_warnings` in backend/src/main.rs).
#
#   POSTGRES_PASSWORD   — MUST NOT be left as the `strata_default` dev value
#   VAULT_TOKEN         — MUST NOT be `root` in production
#   VAULT_ADDR          — should be `https://…` in production (not http://)
#   JWT_SECRET          — at least 32 bytes; never empty in production
#   STRATA_TRUST_XFF    — see "Reverse-proxy trust" section below

# ── Ports ──
# All traffic flows through the frontend nginx gateway on these ports.
HTTP_PORT=3000
HTTPS_PORT=8443

# Base URL for constructing absolute links (e.g. SSO callback redirects).
# Highly recommended for production and required for custom port setups.
# BASE_URL=https://strata.example.com

# ── Logging ──
RUST_LOG=info

# ── Database ──
# Default: uses bundled local PostgreSQL via docker-compose.
# To use an external database, set DATABASE_URL below:
# DATABASE_URL=postgresql://user:password@host:5432/strata

# ── Database SSL ──
# SSL mode for external PostgreSQL connections. Overrides any sslmode param in DATABASE_URL.
# Values: disable, allow, prefer, require, verify-ca, verify-full
# DATABASE_SSL_MODE=require

# Path to a PEM-encoded CA certificate file for verifying the database server.
# Required when DATABASE_SSL_MODE is verify-ca or verify-full.
# Mount or copy the CA cert into the backend container and reference its path here.
# DATABASE_CA_CERT=/app/config/db-ca.pem

# ── Default Admin Account ──
# Created automatically on first boot. Change the password after first login.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin
# JWT Signing Key (persist sessions across restarts). Generate with:
# openssl rand -base64 32
JWT_SECRET=

# ── guacd ──
# GUACD_HOST=guacd
# GUACD_PORT=4822

# ── guacd Scaling (Optional) ──
# Comma-separated list of additional guacd instances for round-robin distribution.
# Requires: docker compose --profile scale up -d
# GUACD_INSTANCES=guacd-2:4822

# ── HTTPS / TLS ──
# TLS is terminated by the frontend nginx gateway. Provide PEM files
# in ./certs/ (mounted read-only into the frontend at /etc/nginx/ssl)
# and set STRATA_DOMAIN to your public hostname.
# STRATA_DOMAIN=strata.example.com

# ── CORS Settings (Optional) ──
# Required for production if the frontend is hosted on a different domain.
# Comma-separated for multiple origins (e.g. split-brain A.7 where
# corp users hit one hostname and public users another).
# STRATA_ALLOWED_ORIGINS=https://strata.example.com
# STRATA_ALLOWED_ORIGINS=https://strata.example.com,https://strata.corp.example.com

# ── Reverse-proxy trust (X-Forwarded-For) ──
# Set to `1` ONLY when a trusted reverse proxy or load balancer terminates
# TLS in front of the backend and adds X-Forwarded-For. Without this gate
# the backend ignores XFF entirely, so a malicious client cannot spoof
# the header to evade per-IP rate limits or forge audit-log source IPs.
# When enabled, populate STRATA_TRUSTED_PROXIES with the LB's IPs/CIDRs.
# STRATA_TRUST_XFF=1
# STRATA_TRUSTED_PROXIES=10.0.0.0/8,192.168.1.5

# ── Web Browser Sessions (Chromium kiosk) ──
# Enabled by default — the unified Debian backend image ships with
# Xvnc + Chromium baked in. Set to false to refuse `web` connections
# even though the binaries are installed (operators who want a fully
# locked-down deployment).
# STRATA_WEB_ENABLED=true
#
# Directory mounted read-only into the backend at
# /var/lib/strata/web-login-scripts. Place operator-supplied
# Playwright/Puppeteer scripts here, one per connection (filename =
# the connection's login_script field). Empty/absent is harmless.
# WEB_LOGIN_SCRIPTS_DIR=./web-login-scripts

# ── VDI Desktop Containers (opt-in via overlay) ──
# Disabled at the default-compose layer. Apply the overlay to enable:
#   docker compose -f docker-compose.yml -f docker-compose.vdi.yml up -d
#
# Or persist the overlay for every compose command by uncommenting
# the COMPOSE_FILE line below. Separator is OS-specific:
#   - Windows:       ';' (semicolon)
#   - Linux / macOS: ':' (colon)
# Once set, plain `docker compose up -d` and any `--force-recreate`
# will keep the docker.sock mount + STRATA_VDI_ENABLED=true.
# COMPOSE_FILE=docker-compose.yml;docker-compose.vdi.yml
#
# The overlay mounts /var/run/docker.sock into the backend
# (host-root). Read docker-compose.vdi.yml's security warning before
# applying.
#
# Persistent-home base directory for `persistent_home=true` VDI
# connections. Must exist on the host with mode 0700 owned by the
# docker daemon's GID.
# VDI_HOME_BASE=./vdi-homes

# ── DMZ split-topology (link-client mode) ──
# Only applies when running the backend on the *internal* host of a
# two-host DMZ deployment. Three internal-host topologies use these
# vars:
#   - A.5: API-only public exposure
#   - A.6: public SPA on the DMZ host (recommended)
#   - A.7: split-brain — public SPA on the DMZ host AND a corp-LAN
#          SPA on the internal host (this same host)
# See docs/deployment.md for full walkthroughs. Apply via the
# shipped overlay (A.5/A.6 — backend-only):
#   docker compose -f docker-compose.yml \
#                  -f docker-compose.internal.yml up -d backend
# Or for A.7, bring up the full internal stack (frontend + backend):
#   docker compose -f docker-compose.yml \
#                  -f docker-compose.internal.yml up -d --build
#
# The overlay already wires the cert paths and node/cluster IDs.
# The values that MUST come from this .env are the DMZ endpoint and
# the two shared base64 secrets — the secrets match the DMZ host's
# `current:` PSK and STRATA_DMZ_EDGE_HMAC_KEY respectively. Leave
# commented for single-host runs.
#
# STRATA_DMZ_ENDPOINTS=dmz-host.example.com:8444
# STRATA_DMZ_LINK_PSK_CURRENT=<base64, matches DMZ current:>
# STRATA_DMZ_EDGE_HMAC_KEYS=<base64, matches STRATA_DMZ_EDGE_HMAC_KEY>
#
# Optional per-host overrides (overlay defaults shown):
# STRATA_NODE_ID=internal-1
# STRATA_CLUSTER_ID=strata-cluster-prod
#
# A.7 reminder: STRATA_ALLOWED_ORIGINS (above) must list BOTH the
# public hostname and the corp-LAN hostname, otherwise the backend
# will reject SPA requests from one of them.

# ── Antivirus scanning for Quick Share uploads ──
# Both upload paths (inbound /api/user/files/upload and outbound
# /api/user/outbound-shares/submit + the token-auth shell-side
# ingest variant) can be wired through a pluggable scanner. The
# scanner runs on the streamed temp file BEFORE it lands in the
# session file store / BEFORE it is sealed via Vault Transit. See
# backend/src/services/av.rs for the full backend + protocol.
#
# Disabled by default — uploads pass through unscanned and the
# audit row records av_scan_status="skipped".
# STRATA_AV_BACKEND=off
#
# Backend selector. One of:
#   off      — no scanning (default).
#   clamav   — talk to a clamd over TCP using the INSTREAM protocol.
#              Bring up the bundled sidecar with:
#                docker compose --profile av up -d
#              (first boot pulls ~250 MB of signatures via freshclam.)
#   command  — shell out to any scanner whose exit codes follow
#              0=clean / 1=infected / other=error. Signature is
#              parsed from the last non-empty stdout (then stderr)
#              line, stripping "Threat: " / "Found: " prefixes.
# STRATA_AV_BACKEND=clamav
#
# What to do when the scanner itself errors (timeout, daemon down,
# connection refused). Infected verdicts are ALWAYS rejected
# regardless of this setting.
#   block    — reject the upload (fail-closed, default).
#   allow    — let it through; the audit row still records the error.
# STRATA_AV_FAIL_MODE=block
#
# Files larger than this are tagged Skipped{reason="oversize"} and
# pass through unscanned. Default 100 MB (104857600). Set to a
# larger value if your clamd has been tuned for big files (see
# clamd.conf MaxFileSize / StreamMaxLength).
# STRATA_AV_MAX_SCAN_SIZE=104857600
#
# Per-scan wall-clock deadline in milliseconds. Exceeded scans
# become Error verdicts and are subject to STRATA_AV_FAIL_MODE.
# Default 30000 (30 s).
# STRATA_AV_TIMEOUT_MS=30000
#
# ── ClamAV backend (only used when STRATA_AV_BACKEND=clamav) ──
# Hostname and port of the clamd TCP listener. The bundled sidecar
# in docker-compose.yml (profile=av) listens on the internal
# `guac-internal` network as `clamav:3310` — no host port mapping.
# STRATA_AV_CLAMD_HOST=clamav
# STRATA_AV_CLAMD_PORT=3310
#
# ── Command backend (only used when STRATA_AV_BACKEND=command) ──
# Full command line. `{path}` is substituted with the absolute path
# of the file to scan; if `{path}` is absent the path is appended
# as the final argv element. The command runs from the backend
# container, so it MUST be installed inside the backend image (the
# stock image does NOT ship any third-party scanner — you'll need
# to extend the Dockerfile). Examples:
#   STRATA_AV_CMD=/usr/bin/clamscan --no-summary --infected {path}
#   STRATA_AV_CMD=/opt/microsoft/mdatp/sbin/wdavdaemonclient scan custom --path {path}
# STRATA_AV_CMD=
