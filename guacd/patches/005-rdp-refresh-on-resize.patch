From: Strata Client <strata@local>
Subject: [PATCH] rdp/disp: send Refresh Rect after dynamic display resize

Force a full-screen Refresh Rect after SendMonitorLayout to repaint regions
the Windows server skips via SaveScreenBits, eliminating black ghost regions
after display-update resize.
---
diff --git a/src/protocols/rdp/channels/disp.c b/src/protocols/rdp/channels/disp.c
--- a/src/protocols/rdp/channels/disp.c
+++ b/src/protocols/rdp/channels/disp.c
@@ -195,16 +195,41 @@ void guac_rdp_disp_update_size(guac_rdp_disp* disp,
 
         /* Send display update notification if display channel is connected */
         if (disp->disp != NULL) {
 
             guac_client* client = disp->client;
             guac_rdp_client* rdp_client = (guac_rdp_client*) client->data;
 
             pthread_mutex_lock(&(rdp_client->message_lock));
             disp->disp->SendMonitorLayout(disp->disp, 1, monitors);
+
+            /*
+             * Force a full-screen Refresh Rect after the monitor layout
+             * change. The Windows RDP server reallocates the RDPGFX
+             * surface on resize but uses SaveScreenBits to skip
+             * "unchanged" regions, leaving the client's freshly-zeroed
+             * surface with permanent black rectangles. Issuing an
+             * explicit Refresh Rect PDU here forces the server to
+             * repaint the entire desktop regardless of its cache.
+             */
+            if (rdp_inst != NULL && rdp_inst->context != NULL
+                    && rdp_inst->context->update != NULL
+                    && rdp_inst->context->update->RefreshRect != NULL) {
+                RECTANGLE_16 refresh_area = {
+                    .left   = 0,
+                    .top    = 0,
+                    .right  = (UINT16) width,
+                    .bottom = (UINT16) height
+                };
+                rdp_inst->context->update->RefreshRect(rdp_inst->context, 1, &refresh_area);
+                guac_client_log(client, GUAC_LOG_DEBUG,
+                        "Sent post-resize Refresh Rect (%dx%d) to force full repaint",
+                        width, height);
+            }
+
             pthread_mutex_unlock(&(rdp_client->message_lock));
 
         }
 
     }
 
 }
