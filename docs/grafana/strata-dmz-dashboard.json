{
  "title": "Strata DMZ",
  "uid": "strata-dmz",
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "tags": ["strata", "dmz"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "refresh": "30s",
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "cluster",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prom" },
        "query": "label_values(strata_dmz_links_up, cluster_id)",
        "refresh": 1,
        "includeAll": true,
        "multi": false
      },
      {
        "name": "node",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prom" },
        "query": "label_values(strata_dmz_links_up{cluster_id=~\"$cluster\"}, node_id)",
        "refresh": 1,
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Links up",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prom" },
      "targets": [
        {
          "expr": "sum(strata_dmz_links_up{cluster_id=~\"$cluster\",node_id=~\"$node\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Public RPS",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prom" },
      "targets": [
        {
          "expr": "sum(rate(strata_dmz_proxy_requests_total{cluster_id=~\"$cluster\",node_id=~\"$node\"}[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "5xx rate",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prom" },
      "targets": [
        {
          "expr": "sum(rate(strata_dmz_proxy_requests_total{cluster_id=~\"$cluster\",node_id=~\"$node\",status=~\"5..\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Rate-limit drops/s",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prom" },
      "targets": [
        {
          "expr": "sum(rate(strata_dmz_rate_limit_drops_total{cluster_id=~\"$cluster\",node_id=~\"$node\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Link reconnects (last 1h)",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prom" },
      "targets": [
        {
          "expr": "sum(increase(strata_dmz_link_reconnects_total{cluster_id=~\"$cluster\",node_id=~\"$node\"}[1h]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Open WS streams",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prom" },
      "targets": [
        {
          "expr": "sum(strata_dmz_websocket_streams{cluster_id=~\"$cluster\",node_id=~\"$node\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Public request rate by status class",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prom" },
      "targets": [
        {
          "expr": "sum by (status_class) (rate(strata_dmz_proxy_requests_total{cluster_id=~\"$cluster\",node_id=~\"$node\"}[1m]))",
          "refId": "A",
          "legendFormat": "{{status_class}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Proxy latency p50 / p95 / p99",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prom" },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(strata_dmz_proxy_duration_seconds_bucket{cluster_id=~\"$cluster\",node_id=~\"$node\"}[5m])))",
          "refId": "A",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(strata_dmz_proxy_duration_seconds_bucket{cluster_id=~\"$cluster\",node_id=~\"$node\"}[5m])))",
          "refId": "B",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(strata_dmz_proxy_duration_seconds_bucket{cluster_id=~\"$cluster\",node_id=~\"$node\"}[5m])))",
          "refId": "C",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Edge-signer latency p95",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prom" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(strata_dmz_edge_sign_duration_seconds_bucket{cluster_id=~\"$cluster\",node_id=~\"$node\"}[5m])))",
          "refId": "A",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Per-link state (1 = up)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prom" },
      "targets": [
        {
          "expr": "strata_dmz_links_up{cluster_id=~\"$cluster\",node_id=~\"$node\"}",
          "refId": "A",
          "legendFormat": "{{node_id}} ↔ {{endpoint}}"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Body-limit / timeout drops",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prom" },
      "targets": [
        {
          "expr": "sum by (reason) (rate(strata_dmz_proxy_drops_total{cluster_id=~\"$cluster\",node_id=~\"$node\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "DMZ container resident memory",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prom" },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"strata-dmz\",cluster_id=~\"$cluster\",node_id=~\"$node\"}",
          "refId": "A",
          "legendFormat": "{{node_id}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ]
}
