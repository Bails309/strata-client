# ─── Strata Client – Caddy Reverse Proxy ───────────────────────────
# All traffic flows through Caddy.
# Plain HTTP by default; set STRATA_DOMAIN to a real domain for
# automatic Let's Encrypt HTTPS.
#
# Usage:
#   docker compose up -d                              # HTTP on :80
#   STRATA_DOMAIN=strata.example.com docker compose up -d  # auto-HTTPS
# ───────────────────────────────────────────────────────────────────

{$STRATA_DOMAIN::80} {
	# API and WebSocket traffic → Rust backend
	handle /api/* {
		reverse_proxy backend:8080 {
			# Long-lived WebSocket tunnels for remote sessions
			transport http {
				read_timeout  3600s
				write_timeout 3600s
			}
			# Stream frames immediately — no response buffering
			flush_interval -1
		}
	}

	# Everything else → nginx frontend container (SPA static files)
	handle {
		reverse_proxy frontend:80
	}

	# Compression
	encode gzip zstd

	# Security headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	# HSTS only when serving over TLS (real domain with certificate)
	@https protocol https
	header @https Strict-Transport-Security "max-age=31536000; includeSubDomains"
}
